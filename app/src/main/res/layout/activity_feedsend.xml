<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFD72E"
    tools:context=".feedsend">

    <ImageView
        android:id="@+id/sucess"
        android:layout_width="match_parent"
        android:layout_height="390dp"
        android:layout_alignParentEnd="true"
        android:layout_gravity="center"
        android:layout_marginTop="150dp"
        android:layout_marginEnd="-12dp"
        android:adjustViewBounds="true"
        app:srcCompat="@drawable/feedback"
        tools:layout_editor_absoluteX="-10dp"
        tools:layout_editor_absoluteY="-69dp" />

    <Button
        android:id="@+id/closeButton"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_alignTop="@id/sucess"
        android:layout_alignEnd="@id/sucess"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/close_white" />

</RelativeLayout>